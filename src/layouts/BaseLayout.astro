---
interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  tags?: string[];
  image?: string;
}

const {
  title,
  description = 'Preston Peranich — research engineer, systems thinker, open-source builder',
  type = 'website',
  publishedDate,
  tags,
  image,
} = Astro.props;
const ogImage = new URL(image || defaultOgImage.src, Astro.site).toString();
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | Preston Peranich`;

const navItems = [
  { href: '/posts', label: 'Posts' },
  { href: '/tags', label: 'Tags' },
  { href: '/apps', label: 'Apps' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
  { href: '/resume.pdf', label: 'Resume' },
];

import { ClientRouter } from 'astro:transitions';
import SocialLinks from '../components/SocialLinks.astro';
import defaultOgImage from '../assets/headshot.jpg';
---

<html lang="en" x-data="{ theme: localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'), navOpen: false }" x-bind:data-theme="theme" x-bind:class="{ 'theme-ready': true }" x-init="$watch('theme', val => localStorage.setItem('theme', val))">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="Preston Peranich" href="/rss.xml" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>

    <!-- OpenGraph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Preston Peranich" />
    <meta property="og:image" content={ogImage} />
    {type === 'article' && publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}
    {type === 'article' && tags?.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

    <ClientRouter />
    <style is:inline>
      .theme-icon-light, .theme-icon-dark { display: none; }
      [data-theme="light"] .theme-icon-light { display: block; }
      [data-theme="dark"] .theme-icon-dark { display: block; }
    </style>
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <header>
      <nav>
        <a href="/" class="site-title">Preston Peranich</a>
        <button class="nav-toggle" x-on:click="navOpen = !navOpen" aria-label="Toggle navigation">
          <svg x-show="!navOpen" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" role="img" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
          <svg x-show="navOpen" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" role="img" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
        <div class="nav-links" x-bind:class="{ open: navOpen }">
          {navItems.map(({ href, label }) => (
            <a
              href={href}
              class:list={[{ active: currentPath.startsWith(href) }]}
              target={href.endsWith('.pdf') ? '_blank' : undefined}
              rel={href.endsWith('.pdf') ? 'noopener' : undefined}
              x-on:click="navOpen = false"
            >
              {label}
            </a>
          ))}
          <button
            class="theme-toggle"
            x-on:click="theme = theme === 'light' ? 'dark' : 'light'"
            aria-label="Toggle theme"
          >
            <svg class="theme-icon-light" x-show="theme === 'light'" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="img" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
            <svg class="theme-icon-dark" x-show="theme === 'dark'" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" role="img" aria-hidden="true"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
          </button>
        </div>
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(
      type === 'article' ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": title,
        "description": description,
        "datePublished": publishedDate?.toISOString(),
        "url": canonicalURL.toString(),
        "author": {
          "@type": "Person",
          "name": "Preston Peranich",
        },
        ...(tags?.length ? { "keywords": tags.join(", ") } : {}),
      } : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Preston Peranich",
        "url": Astro.site?.toString(),
        "author": {
          "@type": "Person",
          "name": "Preston Peranich",
          "url": Astro.site?.toString(),
          "jobTitle": "Research Engineer",
          "worksFor": {
            "@type": "Organization",
            "name": "Johns Hopkins Applied Physics Laboratory"
          }
        }
      }
    )} />
    <footer>
      <div class="footer-content">
        <p>&copy; {new Date().getFullYear()} Preston Peranich</p>
        <SocialLinks />
      </div>
    </footer>
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.5rem 1rem;
    background: rgb(var(--color-accent));
    color: #fff;
    border-radius: 0 0 0.25rem 0.25rem;
    font-size: 0.85rem;
    text-decoration: none;
    z-index: 200;
  }

  .skip-link:focus {
    top: 0;
  }

  :root {
    --font-body: 'IBM Plex Mono', 'JetBrains Mono', 'Fira Code', monospace;
    --color-fill: 251, 254, 251;
    --color-text: 40, 39, 40;
    --color-accent: 0, 108, 172;
    --color-muted: 120, 120, 120;
    --color-card: 240, 240, 240;
    --color-border: 220, 220, 220;
    --max-width: 48rem;
  }

  [data-theme="dark"] {
    --color-fill: 17, 17, 21;
    --color-text: 220, 224, 232;
    --color-accent: 255, 120, 20;
    --color-muted: 145, 150, 165;
    --color-card: 28, 28, 35;
    --color-border: 45, 48, 58;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  *:focus-visible {
    outline: 2px solid rgb(var(--color-accent));
    outline-offset: 2px;
  }

  html {
    font-family: var(--font-body);
    font-size: 16px;
    font-variant-numeric: tabular-nums;
    background: rgb(var(--color-fill));
    color: rgb(var(--color-text));
    line-height: 1.7;
  }

  html.theme-ready {
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  body {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  ::selection {
    background: rgba(var(--color-accent), 0.25);
  }

  /* Header & Nav */
  header {
    margin-bottom: 3rem;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(var(--color-border), 0.6);
  }

  .site-title {
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
    color: rgb(var(--color-text));
    transition: color 0.15s ease;
  }

  .site-title:hover {
    color: rgb(var(--color-accent));
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: rgb(var(--color-text));
    padding: 0.25rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-links a {
    color: rgb(var(--color-text));
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    text-underline-offset: 0.25rem;
    transition: color 0.15s ease;
  }

  .nav-links a:hover {
    color: rgb(var(--color-accent));
  }

  .nav-links a.active {
    color: rgb(var(--color-accent));
    text-decoration: underline;
    text-decoration-style: wavy;
    text-underline-offset: 0.25rem;
  }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: rgb(var(--color-text));
    padding: 0.25rem;
    display: grid;
    place-items: center;
    transition: color 0.15s ease, transform 0.15s ease;
  }

  .theme-toggle svg {
    grid-area: 1 / 1;
  }

  .theme-toggle:hover {
    color: rgb(var(--color-accent));
    transform: rotate(15deg);
  }

  /* Main content */
  main {
    min-height: 65vh;
    animation: fade-in 0.3s ease-out;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    main { animation: none; }
    html.theme-ready { transition: none; }
  }

  /* Footer */
  footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(var(--color-border), 0.6);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: rgb(var(--color-muted));
    font-size: 0.8rem;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .social-links a {
    color: rgb(var(--color-muted));
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: color 0.15s ease;
  }

  .social-links a:hover {
    color: rgb(var(--color-accent));
  }

  /* Typography */
  a {
    color: rgb(var(--color-accent));
  }

  h1, h2, h3, h4 {
    line-height: 1.35;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  h1 {
    font-size: 1.75rem;
    letter-spacing: -0.01em;
  }

  h2 { font-size: 1.35rem; }
  h3 { font-size: 1.15rem; }

  p {
    margin-bottom: 1rem;
  }

  /* Code */
  code {
    font-family: var(--font-body);
    background: rgba(var(--color-card), 0.8);
    border: 1px solid rgba(var(--color-border), 0.3);
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  pre {
    padding: 1rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(var(--color-border), 0.4);
    overflow-x: auto;
    margin-bottom: 1.25rem;
    font-size: 0.85rem;
  }

  pre code {
    background: none;
    border: none;
    padding: 0;
  }

  pre::-webkit-scrollbar {
    height: 6px;
  }

  pre::-webkit-scrollbar-track {
    background: transparent;
  }

  pre::-webkit-scrollbar-thumb {
    background: rgba(var(--color-border), 0.5);
    border-radius: 3px;
  }

  hr {
    border: none;
    border-top: 1px solid rgba(var(--color-border), 0.6);
    margin: 2rem 0;
  }

  /* Post cards */
  .post-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.25rem 0 1.25rem 0;
    border-bottom: 1px solid rgba(var(--color-border), 0.4);
    border-left: 2px solid transparent;
    transition: border-left-color 0.15s ease, padding-left 0.15s ease;
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-card:hover {
    padding-left: 0.75rem;
    border-left-color: rgb(var(--color-accent));
  }

  .post-card:hover .post-title {
    color: rgb(var(--color-accent));
  }

  .post-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 0.25rem;
    text-decoration-color: rgba(var(--color-accent), 0.4);
    transition: color 0.15s ease;
  }

  .post-meta {
    font-size: 0.8rem;
    color: rgb(var(--color-muted));
    margin-bottom: 0.25rem;
  }

  .post-description {
    font-size: 0.85rem;
    color: rgb(var(--color-muted));
    margin: 0;
  }

  /* Tags */
  .tag {
    display: inline-block;
    font-size: 0.7rem;
    padding: 0.1rem 0.5rem;
    background: rgba(var(--color-card), 0.8);
    border-radius: 1rem;
    color: rgb(var(--color-muted));
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .tag:hover {
    color: rgb(var(--color-accent));
    background: rgba(var(--color-accent), 0.1);
  }

  .post-card .tag {
    pointer-events: none;
  }

  .post-card .tag:hover {
    color: rgb(var(--color-muted));
    background: rgba(var(--color-card), 0.8);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  /* Shared page elements */
  .back-link {
    font-size: 0.85rem;
    text-decoration: none;
    color: rgb(var(--color-muted));
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    color: rgb(var(--color-accent));
  }

  .subtitle {
    color: rgb(var(--color-muted));
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  /* Mobile */
  @media (max-width: 640px) {
    body {
      padding: 2rem 1rem;
    }

    h1 {
      font-size: 1.4rem;
    }

    .nav-toggle {
      display: flex;
      align-items: center;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgb(var(--color-fill));
      border-bottom: 1px solid rgba(var(--color-border), 0.6);
      padding: 1rem 1.5rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
      z-index: 100;
    }

    .nav-links.open {
      display: flex;
    }

    nav {
      position: relative;
    }

    .footer-content {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
