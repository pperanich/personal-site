---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Home">
  <section class="hero">
    <h1>Hey, I'm Preston</h1>
    <p>
      Research engineer at <a href="https://www.jhuapl.edu">Johns Hopkins APL</a>
      working on neural interfaces, real-time sensing systems, and open-source embedded
      firmware. I write about Rust, Nix, and the infrastructure that holds it all together.
    </p>
    <div class="social-wrapper">
      <span class="social-label">Social Links:</span>
      <div class="social-links">
        <a href="https://github.com/pperanich" target="_blank" rel="noopener" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://linkedin.com/in/preston-peranich-74166812a" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://scholar.google.com/citations?user=WDM22cwAAAAJ" target="_blank" rel="noopener" aria-label="Google Scholar">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
        </a>
        <a href="mailto:pperanich@gmail.com" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        </a>
      </div>
    </div>
  </section>

  <section>
    <h2>Recent Posts</h2>
    <div class="post-list">
      {posts.map((post) => (
        <a href={`/posts/${post.id}`} class="post-card">
          <h3 class="post-title">{post.data.title}</h3>
          <span class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </span>
          <p class="post-description">{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          )}
        </a>
      ))}
    </div>
    <a href="/posts" class="view-all">All posts &rarr;</a>
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 3rem;
  }

  .hero h1 {
    margin-bottom: 0.75rem;
  }

  .hero p {
    color: rgb(var(--color-muted));
    max-width: 36rem;
  }

  .hero > p a {
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 0.2rem;
  }

  .social-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .social-label {
    font-size: 0.85rem;
    color: rgb(var(--color-muted));
  }

  .hero .social-links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .hero .social-links a {
    color: rgb(var(--color-muted));
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: color 0.15s ease, transform 0.15s ease;
  }

  .hero .social-links a:hover {
    color: rgb(var(--color-accent));
    transform: rotate(6deg);
  }

  section h2 {
    margin-bottom: 0.5rem;
  }

  .post-list {
    margin: 0.5rem 0 1.5rem;
  }

  .view-all {
    font-size: 0.9rem;
    text-decoration: none;
  }

  .view-all:hover {
    text-decoration: underline;
    text-decoration-style: dashed;
  }
</style>
