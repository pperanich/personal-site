---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { Image } from 'astro:assets';
import headshot from '../assets/headshot.jpg';
import { getSortedPosts } from '../lib/posts';

const posts = (await getSortedPosts()).slice(0, 5);
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="hero-intro">
      <div class="hero-text">
        <h1>Hey, I'm Preston</h1>
        <p>
          Research engineer at <a href="https://www.jhuapl.edu">Johns Hopkins APL</a>
          working on neural interfaces, real-time sensing systems, and open-source embedded
          firmware. I write about Rust, Nix, and the infrastructure that holds it all together.
        </p>
        <SocialLinks size={20} />
      </div>
      <Image
        src={headshot}
        alt="Preston Peranich"
        class="hero-headshot"
        width={140}
        quality={85}
      />
    </div>
  </section>

  <section>
    <h2>Recent Posts</h2>
    <div class="post-list">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
    <a href="/posts" class="view-all">All posts &rarr;</a>
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 3rem;
  }

  .hero-intro {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .hero-headshot {
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero h1 {
    margin-bottom: 0.75rem;
  }

  .hero p {
    color: rgb(var(--color-muted));
    max-width: 36rem;
  }

  .hero-text p a {
    text-decoration: underline;
    text-decoration-style: dashed;
    text-underline-offset: 0.2rem;
  }

  @media (max-width: 640px) {
    .hero-intro {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

  }


  section h2 {
    margin-bottom: 0.5rem;
  }

  .post-list {
    margin: 0.5rem 0 1.5rem;
  }

  .view-all {
    font-size: 0.9rem;
    text-decoration: none;
  }

  .view-all:hover {
    text-decoration: underline;
    text-decoration-style: dashed;
  }
</style>
