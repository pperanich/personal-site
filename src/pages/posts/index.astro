---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getSortedPosts } from '../../lib/posts';

const posts = await getSortedPosts();
---

<BaseLayout title="Posts" description="All blog posts">
  <div
    x-data="{
      query: '',
      allPosts: [],
      results: [],
      fuse: null,
      debounceTimer: null,
      async init() {
        const res = await fetch('/search-index.json');
        this.allPosts = await res.json();
        const Fuse = (await import('fuse.js')).default;
        this.fuse = new Fuse(this.allPosts, {
          keys: [
            { name: 'title', weight: 0.5 },
            { name: 'description', weight: 0.3 },
            { name: 'tags', weight: 0.2 }
          ],
          threshold: 0.4,
          includeScore: true,
          minMatchCharLength: 2
        });
        const params = new URLSearchParams(window.location.search);
        if (params.get('q')) {
          this.query = params.get('q');
          this.search();
        }
      },
      search() {
        clearTimeout(this.debounceTimer);
        this.debounceTimer = setTimeout(() => {
          if (this.query.length >= 2 && this.fuse) {
            this.results = this.fuse.search(this.query).map(r => r.item);
          } else {
            this.results = [];
          }
        }, 150);
      }
    }"
    x-effect="search()"
  >
    <h1>All Posts</h1>

    <div class="search-bar">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input
        type="text"
        placeholder="Search posts..."
        x-model="query"
        aria-label="Search posts"
      />
      <span class="result-count" x-show="query.length >= 2" x-text="`${results.length} result${results.length !== 1 ? 's' : ''}`"></span>
    </div>

    <p class="subtitle" x-show="query.length < 2">{posts.length} posts</p>

    <div class="post-list" x-show="query.length < 2">
      {posts.map((post) => <PostCard post={post} />)}
    </div>

    <div class="post-list" x-show="query.length >= 2">
      <template x-for="post in results" :key="post.id">
        <a :href="`/posts/${post.id}`" class="post-card">
          <h2 class="post-title" x-text="post.title"></h2>
          <span class="post-meta">
            <time x-text="new Date(post.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })"></time>
          </span>
          <p class="post-description" x-text="post.description"></p>
          <div class="tags" x-show="post.tags.length > 0">
            <template x-for="tag in post.tags" :key="tag">
              <span class="tag" x-text="tag"></span>
            </template>
          </div>
        </a>
      </template>
      <p class="no-results" x-show="query.length >= 2 && results.length === 0">No posts found.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .search-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(var(--color-border), 0.6);
    border-radius: 0.5rem;
    margin: 1rem 0;
    color: rgb(var(--color-muted));
    transition: border-color 0.15s ease;
  }

  .search-bar:focus-within {
    border-color: rgb(var(--color-accent));
  }

  .search-bar input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: rgb(var(--color-text));
  }

  .search-bar input::placeholder {
    color: rgb(var(--color-muted));
  }

  .result-count {
    font-size: 0.75rem;
    color: rgb(var(--color-muted));
    white-space: nowrap;
  }

  .no-results {
    color: rgb(var(--color-muted));
    font-size: 0.9rem;
    padding: 2rem 0;
  }

  .post-title {
    font-size: 1.1rem;
  }
</style>
